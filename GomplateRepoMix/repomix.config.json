{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "filePath": "repomix_bundle/icalps_pipeline_context.xml",
    "style": "xml",
    "headerText": "IC'ALPS pipeline schema bundle. Scope: rendered SQL upsert patterns, bidirectional StackSync sync contract, and association bridge patterns only. Snakemake, dbt model authoring, Python transforms, Bronze payloads, and memory/reference dumps are intentionally out of scope.",
    "showLineNumbers": true,
    "removeComments": false,
    "removeEmptyLines": false
  },
  "include": [
    "../sql/rendered/*.sql",
    "../sql/templates/*.tmpl",
    "../docs/CANONICAL_EXECUTION_SPEC.md",
    "../docs/CONTEXT_PACKAGING_PROCESS.md",
    "../ValidationRules/icalps_crm_schema.yaml",
    "../ValidationRules/icalps_import_flags.md",
    "fk_cascade_graph.mmd",
    "schema_context.yaml",
    "run_context.yaml"
  ],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "*.env",
      "*.log",
      "*.parquet",
      "rendered_python/**",
      "bronze_layer/**",
      "gold_layer/**",
      "memory/**",
      "benchmark/**",
      "artifacts/**"
    ]
  }
}

# .env.example — required environment variables for the IC_Load pipeline.
# Copy to .env and fill in values. Never commit .env.
#
# See IC_Load_Production_Plan.md §9.2 for the complete contract.

# -----------------------------------------------------------------------------
# PostgreSQL (StackSync-hosted)
# -----------------------------------------------------------------------------
# These drive context/db.py.
ICALPS_PGHOST=your-stacksync-host.postgres.stacksync.com
ICALPS_PGPORT=5432
ICALPS_PGDATABASE=postgres
ICALPS_PGUSER=postgres
ICALPS_PGPASSWORD=
ICALPS_PG_CONNECT_TIMEOUT=10

# -----------------------------------------------------------------------------
# HubSpot (API-native operations only — NOT used by the StackSync-native path)
# -----------------------------------------------------------------------------
# Required only when scripts call the HubSpot API directly (e.g.
# create_company_hierarchy.py, upsert_sibling_companies.py). The main
# Bronze→Silver→Gold pipeline does NOT touch HubSpot directly.
HUBSPOT_ACCESS_TOKEN=

# Portal-level identifiers (confirmed for portal 9201667).
SIBLING_COMPANY_OBJECT_TYPE_ID=2-58895904

# -----------------------------------------------------------------------------
# Pipeline runtime
# -----------------------------------------------------------------------------
# Where artifacts land (JSON run artifacts + structured .log files).
PIPELINE_ARTIFACTS_DIR=./artifacts

# -----------------------------------------------------------------------------
# Bronze extraction
# -----------------------------------------------------------------------------
# Directory containing the Bronze CSV files (Bronze_Company.csv, etc).
# context.config.latest_bronze_path() scans this directory.
BRONZE_CSV_DIR=./bronze_layer

# -----------------------------------------------------------------------------
# library_files module — REST migration of legacy Library files → HubSpot Notes
# -----------------------------------------------------------------------------
# Sandbox HubSpot Private App token. Portal id stored separately so the token
# alone is not bound to a portal in code.
HUBSPOT_SANDBOX_TOKEN=
HUBSPOT_SANDBOX_PORTAL_ID=

# Local filesystem root for legacy IC'ALPS Library files.
LIBRARY_BASE_DIR=

# Optional: prod postgres read-only DSN (Unit 4+).
PROD_POSTGRES_DSN=

# -----------------------------------------------------------------------------
# library_files approval gates (Phase 6) — DEFAULT: DRY-RUN
# -----------------------------------------------------------------------------
# Both unset → runner enumerates + resolves but never POSTs to HubSpot.
# Set to exactly "1" to enable that phase. Anything else (empty, "true", "yes")
# is treated as DRY.
#
# Recommended pattern:
#   1. Run unset → review the dry_run ledger
#   2. Set ICALPS_APPROVE_FILES_UPLOAD=1 → upload files only, inspect HubSpot UI
#   3. Set ICALPS_APPROVE_FILE_NOTES_POST=1 → create notes + associations
#
# ICALPS_APPROVE_FILES_UPLOAD=1
# ICALPS_APPROVE_FILE_NOTES_POST=1

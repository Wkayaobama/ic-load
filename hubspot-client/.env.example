# HubSpot client — configuration for form creation + property management.
# This package handles ONE-TIME setup operations only.
# Data flow goes through managed Postgres + StackSync.

# HubSpot private app token (Bearer auth).
# Required scopes depend on mode:
#   create form:      forms
#   update from CSV:  forms + crm.objects.contacts.read
#   deal preflight:   crm.objects.deals.read + crm.schemas.deals.read
HUBSPOT_ACCESS_TOKEN=

# Alternative token for sandbox testing.
HUBSPOT_SANDBOX_TOKEN=

# Portal ID (numeric).
HUBSPOT_PORTAL_ID=9201667

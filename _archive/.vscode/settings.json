{
  "// purpose": "Workspace settings for the IC_Load pipeline. See docs/TRACEABILITY.md for the contract this implements.",

  "// python": "Point Python tooling at the repo root for correct module resolution.",
  "python.analysis.extraPaths": ["."],
  "python.analysis.autoImportCompletions": true,
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": ["tests"],

  "// files": "Associate pipeline file types correctly.",
  "files.associations": {
    "*.sql.tmpl": "jinja-sql",
    "*.sql": "postgres",
    "MANIFEST.yaml": "yaml",
    "profiles.yml": "yaml",
    "dbt_project.yml": "yaml",
    "schema.yml": "yaml"
  },

  "// dbt-power-user": "Integration with dbt Power User extension. See docs/TRACEABILITY.md §1.1.",
  "dbt.dbtIntegration": "core",
  "dbt.fileNameTemplateGenerateModel": "{prefix}_{modelName}",
  "dbt.enableNewLineagePanel": true,
  "dbt.enableMetaColumnTags": true,
  "dbt.queryLimit": 500,
  "dbt.sqlFmtPath": "",

  "// database-client": "Postgres connection skeleton. Credentials intentionally empty — populate from .env or the VS Code secret store. See docs/TRACEABILITY.md §1.2.",
  "database-client.connections": [
    {
      "name": "ic-load-staging",
      "dbType": "PostgreSQL",
      "host": "${env:ICALPS_PGHOST}",
      "port": "${env:ICALPS_PGPORT}",
      "user": "${env:ICALPS_PGUSER}",
      "password": "${env:ICALPS_PGPASSWORD}",
      "database": "${env:ICALPS_PGDATABASE}",
      "schema": "staging",
      "ssl": false,
      "showHidden": false,
      "usingSSH": false
    }
  ],

  "// database-client.sqls": "Pre-registered diagnostic query snippets — right-click Run on a connection.",
  "database-client.defaultSchema": "staging",
  "database-client.disable": false,
  "sqltools.connections": [],

  "// editor": "Consistent formatting discipline.",
  "editor.formatOnSave": false,
  "editor.rulers": [100],
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,

  "// yaml": "Strict YAML validation.",
  "yaml.format.enable": true,
  "yaml.validate": true,
  "yaml.schemas": {
    "https://schemas.getdbt.com/dbt/manifest/v11.json": [
      "dbt/target/manifest.json"
    ]
  },

  "// search": "Keep artifacts and dbt target out of search results.",
  "search.exclude": {
    "**/artifacts/**": true,
    "**/dbt/target/**": true,
    "**/dbt/dbt_packages/**": true,
    "**/sql/rendered/**": true,
    "**/bronze_layer/**": true,
    "**/.pytest_cache/**": true,
    "**/__pycache__/**": true
  }
}

# HubSpot client — configuration for form creation + property management.
# This package handles ONE-TIME setup operations only.
# Data flow goes through managed Postgres + StackSync.
#
# SANDBOX FIRST: always probe sandbox before touching production.
# When HUBSPOT_SANDBOX_TOKEN is set, all operations target sandbox by default.
# Production (portal 9201667) requires explicit --portal-id 9201667 + confirmation.

# Sandbox portal: 49610528 (default target)
# Set this token to work in sandbox mode (safe).
HUBSPOT_SANDBOX_TOKEN=

# Production portal: 9201667
# Only used when HUBSPOT_SANDBOX_TOKEN is unset or --portal-id 9201667 is explicit.
# Requires typing PRODUCTION at the confirmation prompt.
HUBSPOT_ACCESS_TOKEN=

# Portal ID override (optional — defaults to sandbox 49610528).
# Set to 9201667 only after sandbox validation is complete.
# HUBSPOT_PORTAL_ID=49610528

# For the live association sync (StackSync workflows):
# The swap from sandbox to production is done in HubSpot UI —
# change the workflow webhook trigger's private app credentials.
# No code change, no env var change. UI-only swap.

# IC'ALPS shared environment for all worktrees
#
# Copy this file to ONE level above any ic-load worktree (the Codebase root):
#   C:\Users\ayaobama\Documents\AnthonySalesOps\Codebase\.env.icalps
#
# All ic-load worktrees walk up via dotenv.find_dotenv() and read this file.
# Worktree-local `.env` files still work as overrides if you want to deviate
# for a specific session. Precedence: process env > worktree .env > .env.icalps.
#
# Never commit the populated file. `.env.*` is gitignored; only `*.example`
# files are tracked.

# ----- HubSpot tokens -----
HUBSPOT_SANDBOX_TOKEN=__sandbox_private_app_token__
HUBSPOT_SANDBOX_PORTAL_ID=49610528
HUBSPOT_PROD_TOKEN=__prod_private_app_token__

# ----- Files on disk -----
# Local folder where the legacy IC'ALPS library files live.
LIBRARY_BASE_DIR=C:\path\to\legacy\library

# ----- Postgres DSN -----
# StackSync-mirrored postgres. Read-only on hubspot.* schemas;
# read/write on staging.* (where our ledgers live).
PROD_POSTGRES_DSN=postgresql://postgres:__pwd__@__host__.postgres.stacksync.com:5432/postgres

# ----- Approval gates (DO NOT SET HERE) -----
# These are session-level toggles, never durable config:
#   ICALPS_APPROVE_FILES_UPLOAD       — library Phase 1
#   ICALPS_APPROVE_FILE_NOTES_POST    — library Phase 2
#   ICALPS_APPROVE_ARCHIVE            — cleanup Phase E
#   ICALPS_APPROVE_GDPR_DELETE        — cleanup Phase E2 (irreversible)
#   ICALPS_APPROVE_PROP_DELETE        — cleanup Phase F (irreversible)
# Set them inline before each gated run:
#   $env:ICALPS_APPROVE_ARCHIVE = "1"; uv run python -m pipeline.cleanup.runner archive --object deals
# Unset after:
#   Remove-Item env:ICALPS_APPROVE_ARCHIVE

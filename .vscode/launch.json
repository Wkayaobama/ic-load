{
  "version": "0.2.0",
  "// purpose": "Debug configs — run pipeline stages under the Python debugger with breakpoints. Cmd+Shift+D → select config → F5.",
  "configurations": [
    {
      "name": "pipeline: runner (entity prompt)",
      "type": "debugpy",
      "request": "launch",
      "module": "pipeline.runner",
      "args": ["--entity", "${input:entity}"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "pipeline: runner (dry-run, breakpoint-friendly)",
      "type": "debugpy",
      "request": "launch",
      "module": "pipeline.runner",
      "args": ["--entity", "${input:entity}", "--dry-run", "--verbosity", "high"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "pipeline: resume from stage",
      "type": "debugpy",
      "request": "launch",
      "module": "pipeline.runner",
      "args": ["--entity", "${input:entity}", "--resume-from", "${input:resumeStage}"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "pytest: current file",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "-v"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    }
  ],
  "inputs": [
    {
      "id": "entity",
      "type": "pickString",
      "description": "Entity",
      "options": ["company", "contact", "opportunity", "communication", "case"],
      "default": "company"
    },
    {
      "id": "resumeStage",
      "type": "pickString",
      "description": "Resume from stage",
      "options": [
        "PG_FUNCTIONS_INSTALL",
        "BRONZE_LOAD",
        "SILVER_VALIDATE",
        "DBT_STAGING",
        "DBT_INTERMEDIATE",
        "DBT_TEST_SILVER",
        "DBT_MARTS",
        "GOLD_UPSERT",
        "ASSOC_VALIDATE",
        "POST_RUN_VERIFY"
      ],
      "default": "GOLD_UPSERT"
    }
  ]
}
